{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "JSON schema for rpistat configuration",
  "properties": {
    "clients": {
      "additionalProperties": false,
      "description": "Configuration for external service clients",
      "properties": {
        "ipify": {
          "additionalProperties": false,
          "description": "Configuration for the ipify service client",
          "examples": [
            {
              "address": "https://api.ipify.org",
              "timeout": 15
            }
          ],
          "properties": {
            "address": {
              "default": "",
              "description": "Base URL of the service",
              "examples": [
                "https://api.ipify.org"
              ],
              "title": "Address",
              "type": "string"
            },
            "timeout": {
              "default": 1,
              "description": "HTTP client timeout [seconds]",
              "examples": [
                15
              ],
              "title": "Timeout",
              "type": "integer"
            }
          },
          "required": [
            "address",
            "timeout"
          ],
          "title": "ipify service client",
          "type": "object"
        }
      },
      "required": [
        "ipify"
      ],
      "title": "Clients",
      "type": "object"
    },
    "enabled": {
      "default": true,
      "description": "Enable or disable the service",
      "title": "Enabled",
      "type": "boolean"
    },
    "log": {
      "additionalProperties": false,
      "description": "Logger settings",
      "properties": {
        "address": {
          "default": "",
          "description": "(OPTIONAL) Network address of the (r)Syslog daemon (ip:port) or just (:port)",
          "type": "string"
        },
        "format": {
          "default": "JSON",
          "description": "Defines the default log format",
          "enum": [
            "CONSOLE",
            "JSON"
          ],
          "type": "string"
        },
        "level": {
          "default": "DEBUG",
          "description": "Defines the default log level",
          "enum": [
            "EMERGENCY",
            "ALERT",
            "CRITICAL",
            "ERROR",
            "WARNING",
            "NOTICE",
            "INFO",
            "DEBUG"
          ],
          "type": "string"
        },
        "network": {
          "default": "",
          "description": "(OPTIONAL) Network type used by the (r)Syslog",
          "enum": [
            "",
            "udp",
            "tcp"
          ],
          "type": "string"
        }
      },
      "required": [
        "address",
        "format",
        "level",
        "network"
      ],
      "title": "Logger",
      "type": "object"
    },
    "remoteConfigData": {
      "default": "",
      "description": "Base64 encoded JSON configuration data to be used with the 'envvar' provider",
      "title": "Remote Configuration Data",
      "type": "string"
    },
    "remoteConfigEndpoint": {
      "default": "",
      "description": "Remote configuration URL (ip:port), passed to the custom remote loader",
      "title": "Remote Configuration Endpoint",
      "type": "string"
    },
    "remoteConfigPath": {
      "default": "",
      "description": "Remote configuration path in which to search for the configuration data (e.g. '/config/rpistat'), passed to the custom remote loader",
      "title": "Remote Configuration Path",
      "type": "string"
    },
    "remoteConfigProvider": {
      "default": "",
      "description": "Remote configuration source type: 'envvar' or empty (other values require a custom remote loader registered via the config.WithRemoteLoader option)",
      "enum": [
        "",
        "envvar"
      ],
      "title": "Remote Configuration Provider",
      "type": "string"
    },
    "remoteConfigSecretKeyring": {
      "default": "",
      "description": "Path to an optional secret keyring used by the custom remote loader to decrypt the remote configuration data (e.g. '/etc/rpistat/configkey.gpg')",
      "title": "Remote Configuration Secret Keyring",
      "type": "string"
    },
    "servers": {
      "additionalProperties": false,
      "description": "Configuration for exposed servers",
      "properties": {
        "monitoring": {
          "additionalProperties": false,
          "description": "Configuration for the monitoring server",
          "examples": [
            {
              "address": ":65501",
              "timeout": 60
            }
          ],
          "properties": {
            "address": {
              "default": "",
              "description": "HTTP address (ip:port) or just (:port)",
              "examples": [
                ":65501"
              ],
              "title": "Address",
              "type": "string"
            },
            "timeout": {
              "description": "HTTP request timeout [seconds]",
              "examples": [
                60
              ],
              "title": "Timeout",
              "type": "integer"
            }
          },
          "required": [
            "address",
            "timeout"
          ],
          "title": "Monitoring HTTP server",
          "type": "object"
        }
      },
      "required": [
        "monitoring"
      ],
      "title": "Servers",
      "type": "object"
    },
    "shutdown_timeout": {
      "default": 30,
      "description": "Time in seconds to wait on exit for a graceful shutdown.",
      "title": "ShutDown Timeout",
      "type": "integer"
    },
    "stats": {
      "additionalProperties": false,
      "description": "Configuration for the system statistics collection",
      "properties": {
        "excluded_nics": {
          "default": [
            "lo",
            "docker0"
          ],
          "description": "Network interface names to exclude from the reported statistics",
          "examples": [
            [
              "lo",
              "docker0"
            ]
          ],
          "items": {
            "type": "string"
          },
          "title": "Excluded NICs",
          "type": "array"
        }
      },
      "title": "Stats",
      "type": "object"
    }
  },
  "required": [
    "clients",
    "enabled",
    "log",
    "servers"
  ],
  "title": "Configuration for rpistat",
  "type": "object"
}
